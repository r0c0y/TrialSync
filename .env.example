# =============================================================================
# TrialSync Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env

# ─── Band.ai Credentials ───────────────────────────────────────────────
# Get your keys at https://app.band.ai/settings/api-keys
BAND_USER_TOKEN=band_u_your_user_token_here
BAND_USER_TOKEN_2=band_u_your_second_token_here
BAND_BASE_URL=https://app.band.ai

# ─── Band Agent API Keys ───────────────────────────────────────────────
# Leave commented — populated automatically when you click
# "Register Agents" inside the app (Band tab in any trial workspace).
# BAND_AGENT_SCOUT_KEY=
# BAND_AGENT_DESIGNER_KEY=
# BAND_AGENT_AUDITOR_KEY=

# ─── PostgreSQL Database ───────────────────────────────────────────────
# Optional — leave empty to use the high-fidelity in-memory database
# (seeded with 6 landmark trials, evidence, protocols, SAPs, conflicts).
DATABASE_URL=

# ─── Gemini API Keys (one per agent, 1-6) ─────────────────────────────
# Get keys at https://ai.google.dev/
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=
GEMINI_KEY_4=
GEMINI_KEY_5=
GEMINI_KEY_6=

# ─── Groq API Keys (one per agent, 1-6) ───────────────────────────────
# Get keys at https://console.groq.com/keys
GROQ_KEY_1=
GROQ_KEY_2=
GROQ_KEY_3=
GROQ_KEY_4=
GROQ_KEY_5=
GROQ_KEY_6=

# ─── NCBI / PubMed API Keys ───────────────────────────────────────────
# Optional — authenticated requests get 10 req/sec instead of 3.
# Register at https://ncbi.nlm.nih.gov/account/
NCBI_API_KEY_1=
NCBI_API_KEY_2=

# ─── GitHub OAuth ─────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
#   Homepage URL:        http://localhost:3000
#   Callback URL:        http://localhost:3000/api/auth/github/callback
GITHUB_ID=
GITHUB_SECRET=
NEXT_PUBLIC_BASE_URL=http://localhost:3000
